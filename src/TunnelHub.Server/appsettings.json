{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Sqlite": "Data Source=tunnelhub.db"
  },
  "TunnelHub": {
    "BaseDomain": "lvh.me",
    "AppHost": "localhost",
    "MaxTunnelHours": 4,
    "IdleTimeoutMinutes": 5,
    "MaxTunnelsPerKey": 3,
    "ReaperIntervalSeconds": 30
  },
  "Tls": {
    "Enabled": false,
    "HttpPort": 80,
    "HttpsPort": 443
  }
}
