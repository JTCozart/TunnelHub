@page "/admin/tunnels"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@implements IDisposable
@inject TunnelManager Manager
@inject IOptions<TunnelHubOptions> Options
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Active tunnels · Admin</PageTitle>

<h1>Active tunnels</h1>
<p>Every live tunnel across all users. @_sessions.Count active.</p>

@if (_sessions.Count == 0)
{
    <p class="text-muted">No active tunnels.</p>
}
else
{
    <table class="table">
        <thead>
            <tr><th>Subdomain</th><th>Owner</th><th>Client IP</th><th>Started</th><th>Idle</th><th>Expires in</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var t in _sessions)
            {
                <tr>
                    <td><code>@t.Subdomain.@Base</code></td>
                    <td>@OwnerName(t.OwnerId)</td>
                    <td>@(t.ClientIp ?? "—")</td>
                    <td>@t.StartedAt.LocalDateTime.ToString("T")</td>
                    <td>@Ago(t.LastSeen)</td>
                    <td>@Remaining(t.ExpiresAt)</td>
                    <td>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DisconnectAsync(t.Subdomain)">
                            Disconnect
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<TunnelSession> _sessions = [];
    private Dictionary<string, string> _owners = new();
    private System.Threading.Timer? _ticker;
    private string Base => Options.Value.BaseDomain;

    protected override async Task OnInitializedAsync()
    {
        Manager.Registry.Changed += OnChanged;
        await RefreshAsync();
        _ticker = new System.Threading.Timer(_ => InvokeAsync(StateHasChanged), null, 1000, 1000);
    }

    private void OnChanged() => InvokeAsync(async () => { await RefreshAsync(); StateHasChanged(); });

    private async Task RefreshAsync()
    {
        _sessions = Manager.Registry.Active.OrderBy(s => s.Subdomain).ToList();
        var ids = _sessions.Select(s => s.OwnerId).Distinct().ToList();
        await using var db = await DbFactory.CreateDbContextAsync();
        _owners = await db.Users.Where(u => ids.Contains(u.Id))
            .ToDictionaryAsync(u => u.Id, u => u.Email ?? u.UserName ?? u.Id);
    }

    private string OwnerName(string id) => _owners.TryGetValue(id, out var n) ? n : id;

    private async Task DisconnectAsync(string subdomain)
    {
        await Manager.CloseAsync(subdomain, "Disconnected by administrator.");
        await RefreshAsync();
    }

    private static string Ago(DateTimeOffset t)
    {
        var s = (DateTimeOffset.UtcNow - t).TotalSeconds;
        return s < 60 ? $"{(int)s}s" : $"{(int)(s / 60)}m";
    }

    private static string Remaining(DateTimeOffset expires)
    {
        var span = expires - DateTimeOffset.UtcNow;
        if (span <= TimeSpan.Zero) return "expiring…";
        return span.Hours > 0 ? $"{span.Hours}h {span.Minutes}m" : $"{span.Minutes}m";
    }

    public void Dispose()
    {
        Manager.Registry.Changed -= OnChanged;
        _ticker?.Dispose();
    }
}
