                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/keys">
                        <span class="bi bi-key-nav-menu" aria-hidden="true"></span> API keys
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/downloads">
                        <span class="bi bi-download-nav-menu" aria-hidden="true"></span> Downloads
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Admin">
