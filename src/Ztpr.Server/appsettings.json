{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Sqlite": "Data Source=ztpr.db"
  },
  "Ztpr": {
    "MaxTunnelHours": 4,
    "IdleTimeoutMinutes": 5,
    "MaxTunnelsPerKey": 3,
    "ReaperIntervalSeconds": 30
  }
}
