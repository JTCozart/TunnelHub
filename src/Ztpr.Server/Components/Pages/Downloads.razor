@page "/downloads"
@attribute [Authorize]
@inject IWebHostEnvironment Env
@inject SettingsService SettingsSvc

<PageTitle>Downloads · Ztpr</PageTitle>

<h1>Download the client</h1>
<p>Run a reverse-proxy tunnel from your machine. Authenticate with an
   <a href="/keys">API key</a>, then point it at your local app.</p>

<table class="table" style="max-width: 640px;">
    <thead><tr><th>Platform</th><th>File</th><th></th></tr></thead>
    <tbody>
        @foreach (var d in _downloads)
        {
            <tr>
                <td>@d.Platform</td>
                <td><code>@d.FileName</code></td>
                <td>
                    @if (d.Exists)
                    {
                        <a class="btn btn-sm btn-primary" href="@d.Href" download>Download</a>
                    }
                    else
                    {
                        <span class="text-muted small">not built yet</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<h2>Usage</h2>
<pre><code># Windows
ztpr.exe --server @ServerUrl --key &lt;your-api-key&gt; --target http://localhost:3000

# Linux
./ztpr --server @ServerUrl --key &lt;your-api-key&gt; --target http://localhost:3000</code></pre>
<p class="text-muted">The server assigns a random URL like <code>red-tiger.@Base</code> that stays
   live while the client runs (up to @Hours hours).</p>

@code {
    private sealed record Download(string Platform, string FileName, string Href, bool Exists);
    private List<Download> _downloads = [];

    private string Base => SettingsSvc.Current.BaseDomain;
    private int Hours => SettingsSvc.Current.MaxTunnelHours;
    private string ServerUrl => $"https://{SettingsSvc.Current.AppHost}";

    protected override void OnInitialized()
    {
        _downloads =
        [
            Build("Windows (x64)", "ztpr-win-x64.exe"),
            Build("Linux (x64)", "ztpr-linux-x64"),
        ];
    }

    private Download Build(string platform, string file)
    {
        var path = Path.Combine(Env.WebRootPath, "downloads", file);
        return new Download(platform, file, $"/downloads/{file}", File.Exists(path));
    }
}
