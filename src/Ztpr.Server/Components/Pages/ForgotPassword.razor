@page "/forgot-password"
@layout Layout.AuthLayout
@inject SettingsService SettingsSvc

<PageTitle>Reset password · Ztpr</PageTitle>

<div class="auth-card">
    <h1>Reset password</h1>

    @if (!string.IsNullOrEmpty(Sent))
    {
        <div class="alert alert-success" role="alert">
            If an account exists for <strong>@Sent</strong>, we've emailed a link to reset its password.
            Check your inbox (and spam folder).
        </div>
        <p class="mt-3 text-center"><a href="/login">Back to sign in</a></p>
    }
    else if (!_emailAvailable)
    {
        <div class="alert alert-warning" role="alert">
            Password reset by email isn't available on this server. Contact an administrator.
        </div>
        <p class="mt-3 text-center"><a href="/login">Back to sign in</a></p>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-danger" role="alert">@Error</div>
        }
        <p>Enter your email and we'll send you a link to reset your password.</p>
        <form method="post" action="/account/forgot-password">
            <AntiforgeryToken />
            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <input class="form-control" id="email" name="email" type="email" autocomplete="username" required />
            </div>
            <button class="btn btn-primary w-100" type="submit">Send reset link</button>
        </form>
        <p class="mt-3 text-center"><a href="/login">Back to sign in</a></p>
    }
</div>

@code {
    [SupplyParameterFromQuery] private string? Sent { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }

    private bool _emailAvailable;

    protected override void OnInitialized() => _emailAvailable = SettingsSvc.Current.HasEmail;
}
