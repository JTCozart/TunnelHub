@page "/keys"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IServiceScopeFactory ScopeFactory
@inject TunnelManager Manager
@inject AuditLogService Audit
@inject IJSRuntime JS

<PageTitle>API keys · Ztpr</PageTitle>

<h1>API keys</h1>
<p>Hand a key to your tunnel client with <code>--key</code>. The full key is shown only once.</p>

@if (_justCreated is not null)
{
    <div class="alert alert-success">
        <strong>New key created.</strong> Copy it now — it won't be shown again:
        <pre class="mb-0 mt-2">@_justCreated</pre>
    </div>
}

<div class="card mb-4" style="max-width: 480px;">
    <div class="card-body">
        <h5 class="card-title">Create a key</h5>
        <div class="input-group">
            <input class="form-control" placeholder="Label (e.g. laptop)" @bind="_newLabel" />
            <button class="btn btn-primary" @onclick="CreateAsync" disabled="@_busy">Create</button>
        </div>
    </div>
</div>

@if (_keys.Count == 0)
{
    <p class="text-muted">No keys yet.</p>
}
else
{
    <div class="table-responsive">
    <table class="table">
        <thead>
            <tr><th>Label</th><th>Key</th><th>Created</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var k in _keys)
            {
                <tr>
                    <td>@k.Label</td>
                    <td><code>@k.DisplayPrefix</code></td>
                    <td><LocalTime Value="@k.CreatedAt" /></td>
                    <td>
                        @if (k.IsActive)
                        {
                            <span class="badge bg-success">active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">revoked</span>
                        }
                    </td>
                    <td class="text-nowrap">
                        @if (k.IsActive)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RevokeAsync(k.Id)" disabled="@_busy">Revoke</button>
                        }
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => DeleteAsync(k.Id, k.IsActive)" disabled="@_busy">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private List<ApiKey> _keys = [];
    private string _newLabel = "";
    private string? _justCreated;
    private string _userId = "";
    private string? _userEmail;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState;
        _userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "";
        _userEmail = state.User.FindFirstValue(ClaimTypes.Name);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        // SQLite can't ORDER BY DateTimeOffset, so order in memory.
        var keys = await db.ApiKeys.Where(k => k.OwnerId == _userId).ToListAsync();
        _keys = keys.OrderByDescending(k => k.CreatedAt).ToList();
    }

    private async Task CreateAsync()
    {
        if (_busy) return;
        _busy = true;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<ApiKeyService>();
            var created = await svc.CreateAsync(_userId, _newLabel);
            _justCreated = created.RawKey;
            await Audit.LogAsync(AuditEventType.ApiKeyCreated, _userId, _userEmail,
                detail: $"label: {created.Record.Label} ({created.Record.DisplayPrefix})");
            _newLabel = "";
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    private async Task RevokeAsync(Guid id)
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<ApiKeyService>();
        await svc.RevokeAsync(id, _userId);
        await LoadAsync();
    }

    // Permanently remove a key. Active keys back a live tunnel only momentarily, so warn
    // accordingly. Cascade deletes the key's tunnel history; live sessions are closed first.
    private async Task DeleteAsync(Guid id, bool active)
    {
        if (_busy) return;
        var warning = active
            ? "Delete this key permanently? Any tunnel using it will be disconnected, and its history will be removed."
            : "Delete this key permanently? Its tunnel history will be removed.";
        if (!await JS.InvokeAsync<bool>("confirm", warning))
            return;

        _busy = true;
        try
        {
            await Manager.CloseForKeyAsync(id, "API key deleted.");
            using var scope = ScopeFactory.CreateScope();
            var svc = scope.ServiceProvider.GetRequiredService<ApiKeyService>();
            var label = await svc.DeleteAsync(id, _userId);
            if (label is not null)
                await Audit.LogAsync(AuditEventType.ApiKeyDeleted, _userId, _userEmail, detail: $"label: {label}");
            await LoadAsync();
        }
        finally { _busy = false; }
    }
}
