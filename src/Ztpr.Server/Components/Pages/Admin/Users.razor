@page "/admin/users"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IServiceScopeFactory ScopeFactory
@inject TunnelManager Manager
@inject AuditLogService Audit
@inject IJSRuntime JS

<PageTitle>Users · Admin</PageTitle>

<h1>Users</h1>
<p>All accounts, their active tunnels, and block controls.</p>

<div class="table-responsive">
<table class="table">
    <thead>
        <tr><th>Email</th><th>Role</th><th>Registered</th><th>Active tunnels</th><th>Status</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var row in _rows)
        {
            <tr class="@(row.User.IsBlocked ? "table-warning" : null)">
                <td>@row.User.Email</td>
                <td>@(row.IsAdmin ? "Admin" : "User")</td>
                <td><LocalTime Value="@row.User.CreatedAt" Mode="date" /></td>
                <td>
                    @if (row.ActiveSubdomains.Count == 0)
                    {
                        <span class="text-muted">—</span>
                    }
                    else
                    {
                        @string.Join(", ", row.ActiveSubdomains)
                    }
                </td>
                <td>
                    @if (row.User.IsBlocked)
                    {
                        <span class="badge bg-danger">blocked</span>
                    }
                    else if (row.User.IsLocked)
                    {
                        <span class="badge bg-warning text-dark">locked</span>
                    }
                    else
                    {
                        <span class="badge bg-success">active</span>
                    }
                </td>
                <td class="text-nowrap">
                    @if (row.User.IsLocked)
                    {
                        <button class="btn btn-sm btn-outline-warning" @onclick="() => UnlockAsync(row.User.Id)" disabled="@_busy">Unlock</button>
                    }
                    @if (row.IsAdmin)
                    {
                        @if (!row.User.IsLocked)
                        {
                            <span class="text-muted small">protected</span>
                        }
                    }
                    else
                    {
                        @if (row.User.IsBlocked)
                        {
                            <button class="btn btn-sm btn-outline-success" @onclick="() => SetBlockedAsync(row.User.Id, false)" disabled="@_busy">Unblock</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => SetBlockedAsync(row.User.Id, true)" disabled="@_busy">Block</button>
                        }
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => DeleteAsync(row.User.Id, row.User.Email)" disabled="@_busy">Delete</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
</div>

@code {
    private sealed class Row
    {
        public required ApplicationUser User { get; init; }
        public bool IsAdmin { get; init; }
        public List<string> ActiveSubdomains { get; init; } = [];
    }

    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    private List<Row> _rows = [];
    private string? _adminEmail;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState;
        _adminEmail = state.User.FindFirstValue(ClaimTypes.Name);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var users = await db.Users.OrderBy(u => u.Email).ToListAsync();

        // Admin role membership in one query.
        var adminRoleId = await db.Roles.Where(r => r.Name == Roles.Admin).Select(r => r.Id).FirstOrDefaultAsync();
        var adminIds = adminRoleId is null
            ? new HashSet<string>()
            : (await db.UserRoles.Where(ur => ur.RoleId == adminRoleId).Select(ur => ur.UserId).ToListAsync()).ToHashSet();

        var liveByOwner = Manager.Registry.Active
            .GroupBy(s => s.OwnerId)
            .ToDictionary(g => g.Key, g => g.Select(s => s.Subdomain).OrderBy(x => x).ToList());

        _rows = users.Select(u => new Row
        {
            User = u,
            IsAdmin = adminIds.Contains(u.Id),
            ActiveSubdomains = liveByOwner.TryGetValue(u.Id, out var subs) ? subs : [],
        }).ToList();
    }

    private async Task SetBlockedAsync(string userId, bool blocked)
    {
        using var scope = ScopeFactory.CreateScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
        var user = await userManager.FindByIdAsync(userId);
        if (user is null) return;

        user.IsBlocked = blocked;
        user.BlockedAt = blocked ? DateTimeOffset.UtcNow : null;
        await userManager.UpdateAsync(user);
        // Invalidate existing cookies/circuits so the change takes effect immediately.
        await userManager.UpdateSecurityStampAsync(user);

        if (blocked)
            await Manager.CloseForOwnerAsync(userId, "User blocked by administrator.");

        await Audit.LogAsync(blocked ? AuditEventType.UserBlocked : AuditEventType.UserUnblocked,
            user.Id, user.Email, detail: $"by {_adminEmail ?? "admin"}");

        await LoadAsync();
    }

    // Permanently delete a (non-admin) user. Cascade removes their API keys and tunnel
    // history; live tunnels are closed first. Admins are never offered the button.
    private async Task DeleteAsync(string userId, string? email)
    {
        if (_busy) return;
        if (!await JS.InvokeAsync<bool>("confirm",
                $"Permanently delete {email}? Their API keys and tunnel history will be removed and any live tunnels disconnected. This cannot be undone."))
            return;

        _busy = true;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
            var user = await userManager.FindByIdAsync(userId);
            if (user is null) return;

            // Guard: never delete an administrator through this UI (mirrors block).
            if (await userManager.IsInRoleAsync(user, Roles.Admin))
                return;

            await Manager.CloseForOwnerAsync(userId, "Account deleted by administrator.");
            var result = await userManager.DeleteAsync(user);
            if (result.Succeeded)
                await Audit.LogAsync(AuditEventType.UserDeleted, user.Id, user.Email, detail: $"by {_adminEmail ?? "admin"}");

            await LoadAsync();
        }
        finally { _busy = false; }
    }

    private async Task UnlockAsync(string userId)
    {
        using var scope = ScopeFactory.CreateScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
        var user = await userManager.FindByIdAsync(userId);
        if (user is null) return;

        user.IsLocked = false;
        user.LockedAt = null;
        user.BackupCodeFailedCount = 0;
        await userManager.UpdateAsync(user);
        // Rotate the security stamp so the locked-out half-authenticated session is invalidated.
        await userManager.UpdateSecurityStampAsync(user);

        await LoadAsync();
    }
}
