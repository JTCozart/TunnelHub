@page "/login-mfa"
@layout Layout.AuthLayout

<PageTitle>Two-factor sign in · Ztpr</PageTitle>

<div class="auth-card">
    @if (Recovery)
    {
        <h1>Enter a backup code</h1>
        <p class="text-muted">Use one of the backup codes you saved when you enabled MFA. Each code works only once.</p>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-danger" role="alert">@Error</div>
        }

        <form method="post" action="/account/login-mfa-recovery">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <div class="mb-3">
                <label class="form-label" for="code">Backup code</label>
                <input class="form-control" id="code" name="code" type="text" autocomplete="one-time-code"
                       inputmode="text" autofocus required />
            </div>
            <button class="btn btn-primary w-100" type="submit">Verify</button>
        </form>

        <p class="mt-3 text-center">
            <a href="@MfaLink(recovery: false)">Use your authenticator app instead</a>
        </p>
    }
    else
    {
        <h1>Two-factor sign in</h1>
        <p class="text-muted">Enter the 6-digit code from your authenticator app.</p>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-danger" role="alert">@Error</div>
        }

        <form method="post" action="/account/login-mfa">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <div class="mb-3">
                <label class="form-label" for="code">Authenticator code</label>
                <input class="form-control" id="code" name="code" type="text" autocomplete="one-time-code"
                       inputmode="numeric" pattern="[0-9 ]*" autofocus required />
            </div>
            <button class="btn btn-primary w-100" type="submit">Verify</button>
        </form>

        <p class="mt-3 text-center">
            Lost your authenticator? <a href="@MfaLink(recovery: true)">Use a backup code</a>
        </p>
    }
</div>

@code {
    [SupplyParameterFromQuery] private string? Error { get; set; }
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private bool Recovery { get; set; }

    private string MfaLink(bool recovery)
    {
        var qs = recovery ? "?recovery=1" : "";
        if (!string.IsNullOrWhiteSpace(ReturnUrl))
            qs += (qs.Length == 0 ? "?" : "&") + $"returnUrl={Uri.EscapeDataString(ReturnUrl)}";
        return $"/login-mfa{qs}";
    }
}
